# ========== LINE Login ==========
# LINE Developers Console → LINEログインチャネル → チャネル基本設定
LINE_LOGIN_CHANNEL_ID=xxxxxxxx
LINE_LOGIN_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 公式LINEアカウントのベーシックID（@から始まる）
NEXT_PUBLIC_LINE_OA_BASIC_ID=@xxxxxxx

# ========== App ==========
# 本番は https://ai-tool-lab.net、ローカルは http://localhost:3003
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# JWT署名用シークレット（48バイト以上推奨）: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 各ツールからAPIを叩く際のトークン（リクエスト検証用・任意の長いランダム文字列）
TOOL_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
